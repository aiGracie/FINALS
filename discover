<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Meowtch 🐾</title>
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600;700&family=Nunito:wght@400;600;700;800&family=Fredoka+One&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js" defer></script>
</head>
<body>

<!-- PAGE 3: DISCOVER -->
<div class="page" id="page-discover">
  <div class="discover-overlay"></div>

  <!-- APP NAV -->
  <nav class="app-nav">
    <a class="app-nav-logo" href="#"><img src="logotrans.png" alt="Meowtch"><span>Meowtch</span></a>
    <div class="app-nav-tabs">
      <button class="app-nav-tab active" onclick="switchDiscoverTab('discover',this)">₍^. .^₎⟆ Discover</button>
    </div>
    <div class="app-nav-right">
      <button class="nav-icon-btn nav-badge" id="msgNavBtn" data-count="" onclick="showMatchesPanel()" title="Messages">✉</button>
      <button class="nav-profile-btn" onclick="showDashboard()" title="My Profile">👤</button>
      <button class="nav-logout-btn" onclick="doLogout()">Logout 👋</button>
    </div>
  </nav>

  <!-- STATS BAR (real-time, top) -->
  <div class="stats-bar">
    <div class="stat-item"><span class="stat-num" id="statCats">0</span><span class="stat-label">AVAILABLE CATS</span></div>
    <div class="stat-item"><span class="stat-num" id="statMatches">0</span><span class="stat-label">MATCHES TODAY</span></div>
    <div class="stat-item"><span class="stat-num" id="statAdopted">0</span><span class="stat-label">ADOPTED CATS</span></div>
    <div class="stat-item"><span class="stat-num">3</span><span class="stat-label">NEARBY SHELTERS</span></div>
  </div>

  <!-- MAIN DISCOVER AREA -->
  <div class="discover-main">
    <div class="discover-body">

      <!-- LEFT: SWIPE AREA -->
      <div class="card-area">
        <div class="card-tagline">swipe through adoptable cats, match, and give them a forever home 🏠</div>
        <div class="card-stack" id="cardStack">
          <div class="cat-card back-card-2" id="backCard2">
            <div class="cat-card-img-placeholder" style="font-size:0;background:linear-gradient(135deg,rgba(74,158,142,.1),rgba(168,191,138,.15))"></div>
            <div class="card-info"><div class="card-name-row"><span class="card-name" style="color:#ccc">?</span></div></div>
          </div>
          <div class="cat-card back-card-1" id="backCard1">
            <div class="cat-card-img-placeholder" style="font-size:0;background:linear-gradient(135deg,rgba(168,191,138,.15),rgba(212,168,83,.1))"></div>
            <div class="card-info"><div class="card-name-row"><span class="card-name" style="color:#ccc">?</span></div></div>
          </div>
          <div class="cat-card front-card" id="frontCard">
            <div class="swipe-label swipe-like" id="swipeLike">ADOPT! 💚</div>
            <div class="swipe-label swipe-nope" id="swipeNope">PASS 💔</div>
            <img class="cat-card-img" id="cardImg" src="" alt="Cat photo" style="display:none">
            <div class="cat-card-img-placeholder" id="cardImgPlaceholder">🐱</div>
            <div class="card-info">
              <div class="card-name-row">
                <span class="card-name" id="cardName">Jellybean</span>
                <span class="card-age" id="cardAge">1 yr</span>
              </div>
              <div class="card-breed" id="cardBreed">📍 Baguio City • Orange Tabby</div>
              <div class="card-traits" id="cardTraits"></div>
              <div class="card-bio" id="cardBio"></div>
            </div>
          </div>
          <div class="no-more-cats" id="noMoreCats">
            <div class="big-emoji">😿</div>
            <h3>You've seen them all!</h3>
            <p>Check back soon or adjust your filters!</p>
            <button class="btn btn-primary" onclick="resetCards()">🔄 Refresh Cats</button>
          </div>
        </div>
        <div class="action-buttons">
          <button class="action-btn btn-undo" onclick="undoSwipe()" title="Undo">↩️</button>
          <button class="action-btn btn-nope" onclick="swipeLeft()" title="Pass">❌</button>
          <button class="action-btn btn-super" onclick="superLike()" title="Super Like">⭐</button>
          <button class="action-btn btn-like" onclick="swipeRight()" title="Adopt">💚</button>
          <button class="action-btn btn-undo" onclick="boostCard()" title="Boost" style="font-size:15px">⚡</button>
        </div>
        <div class="swipe-hint"><span>👈 Pass</span><span>⭐ Super Like</span><span>💚 Adopt 👉</span></div>
      </div>

      <!-- RIGHT: SIDEBAR -->
      <div class="discover-sidebar">
        <!-- Filters -->
        <div class="sidebar-card">
          <h3>🎛️ Filters</h3>
          <div class="filter-row">
            <span class="filter-label">Max Age</span>
            <span class="filter-val" id="ageVal">Any age</span>
          </div>
          <input type="range" id="ageSlider" min="0" max="15" value="15"
            oninput="document.getElementById('ageVal').textContent=this.value>=15?'Any age':'0–'+this.value+' yrs';applyFilters()">
          <div class="filter-row">
            <span class="filter-label">Distance</span>
            <span class="filter-val" id="distVal">10 km</span>
          </div>
          <input type="range" min="1" max="50" value="10" oninput="document.getElementById('distVal').textContent=this.value+' km'">
          <div class="filter-label" style="margin-bottom:6px">Personality</div>
          <div class="filter-chips">
            <div class="filter-chip active" data-trait="calm" onclick="toggleChip(this);applyFilters()">😴 Calm</div>
            <div class="filter-chip" data-trait="playful" onclick="toggleChip(this);applyFilters()">🏃 Playful</div>
            <div class="filter-chip active" data-trait="cuddly" onclick="toggleChip(this);applyFilters()">🤗 Cuddly</div>
            <div class="filter-chip" data-trait="sassy" onclick="toggleChip(this);applyFilters()">😼 Sassy</div>
            <div class="filter-chip" data-trait="active" onclick="toggleChip(this);applyFilters()">🐾 Active</div>
            <div class="filter-chip" data-trait="shy" onclick="toggleChip(this);applyFilters()">🌙 Shy</div>
          </div>
        </div>

        <!-- Recent Matches -->
        <div class="sidebar-card">
          <h3>♡ Recent Matches</h3>
          <div class="matches-grid" id="sidebarMatchesGrid"></div>
        </div>

        <!-- Nearby Shelters -->
        <div class="sidebar-card">
          <h3>📍 Nearby Shelters</h3>
          <div class="shelter-item">
            <div class="shelter-icon" style="background:rgba(74,158,142,.12)">🏠</div>
            <div class="shelter-info"><div class="shelter-name">Baguio Cat Rescue</div><div class="shelter-dist">⭐ 4.9 • 1.2 km away</div></div>
            <span class="shelter-count">23 cats</span>
          </div>
          <div class="shelter-item">
            <div class="shelter-icon" style="background:rgba(168,191,138,.2)">🐾</div>
            <div class="shelter-info"><div class="shelter-name">PAWS Benguet</div><div class="shelter-dist">⭐ 4.7 • 3.5 km away</div></div>
            <span class="shelter-count">41 cats</span>
          </div>
          <div class="shelter-item">
            <div class="shelter-icon" style="background:rgba(212,168,83,.12)">🌸</div>
            <div class="shelter-info"><div class="shelter-name">Happy Paws Shelter</div><div class="shelter-dist">⭐ 4.8 • 6.1 km away</div></div>
            <span class="shelter-count">17 cats</span>
          </div>
        </div>

        <!-- Adoption Tip -->
        <div class="sidebar-card tip-card">
          <h3>💡 Adoption Tip</h3>
          <p id="adoptionTip">Senior cats (7+ yrs) are often overlooked but make wonderful, calm companions! 🐾</p>
        </div>
      </div>
    </div>

    <!-- MATCHES PANEL -->
    <div class="side-panel" id="matchesPanel">
      <div class="panel-header">
        <div class="panel-title">♡ Your Matches</div>
        <button class="panel-close" onclick="closePanel('matchesPanel')">✕</button>
      </div>
      <div class="matches-list" id="matchesList"></div>
    </div>

    <!-- CHAT PANEL -->
    <div class="side-panel" id="chatPanel">
      <div class="chat-nav">
        <button class="chat-back" onclick="showMatchesPanel()">←</button>
        <div class="chat-partner-info">
          <div class="chat-partner-avatar-placeholder" id="chatPartnerAvatar">🐱</div>
          <div>
            <div class="chat-partner-name" id="chatPartnerName">Cat</div>
            <div class="chat-partner-status">Active now</div>
          </div>
        </div>
        <button class="btn btn-secondary" style="font-size:12px;padding:5px 13px" onclick="viewCatProfile()">View Profile</button>
      </div>
      <div class="chat-messages" id="chatMessages">
        <div class="chat-empty"><div class="chat-empty-icon">💬</div><div>Say hello! Start the conversation 🐾</div></div>
      </div>
      <div class="chat-input-area">
        <input class="chat-input" id="chatInput" placeholder="Type a message..."
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage()}">
        <button class="chat-send" onclick="sendMessage()">➤</button>
      </div>
    </div>
  </div>

  <!-- MOBILE BOTTOM NAV -->
  <nav class="mobile-bottom-nav" id="mobileNav">
    <button class="mob-nav-btn active" id="mobDiscover" onclick="closePanels();setMobActive(this)"><span>🐾</span><span>Discover</span></button>
    <button class="mob-nav-btn" id="mobMatches" onclick="showMatchesPanel();setMobActive(this)"><span>♡</span><span>Matches</span></button>
    <button class="mob-nav-btn" onclick="showDashboard()"><span>👤</span><span>Profile</span></button>
    <button class="mob-nav-btn" onclick="doLogout()"><span>⏻</span><span>Logout</span></button>
  </nav>
</div>

<!-- MATCH POPUP -->
<div class="match-popup" id="matchPopup">
  <div class="match-popup-inner">
    <span class="match-popup-emoji">ᓚᘏᗢ</span>
    <h2>It's a Meowtch!</h2>
    <p id="matchPopupText">You could be a perfect pair!</p>
    <div class="popup-btns">
      <button class="popup-btn popup-btn-primary" onclick="goToMatchChat()">✉ Send a Message</button>
      <button class="popup-btn popup-btn-secondary" onclick="closePopup()">Keep Swiping</button>
    </div>
  </div>
</div>
</body>
